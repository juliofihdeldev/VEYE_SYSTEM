{
  "name": "veye-system",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "dev:dashboard": "pnpm --filter veye-dashboard dev",
    "dev:webapp": "pnpm --filter veye-web-app dev",
    "dev:functions": "pnpm --filter @veye/firebase-functions serve",
    "supabase:serve": "supabase functions serve",
    "supabase:deploy": "supabase functions deploy",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  }
}
