# Copy to .env and fill with your values. Never commit .env.

# HERE reverse geocoding (MapDashboard address lookup)
HERE_API_KEY=your_here_api_key

# Google Maps (android/gradle.properties for maps)
# GOOGLE_MAPS_API_KEY=your_google_maps_key

# OneSignal push notifications
ONESIGNAL_APP_ID=your_onesignal_app_id

# Notification API auth (Supabase anon JWT for Cloud Function)
NOTIFICATION_AUTH_TOKEN=your_jwt_token
