# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

use_frameworks! :linkage => :static
$RNFirebaseAsStaticFramework = true

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'veyeapp' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
    )
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |cfg|
        cfg.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.4'
        cfg.build_settings['ENABLE_BITCODE'] = 'NO'
        # RNFirebase + use_frameworks!: React-Core headers are non-modular when built as frameworks
        cfg.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
        # Prebuilt ReactNativeDependencies omits folly/coro; Portability.h sets FOLLY_HAS_COROUTINES from this.
        defs = cfg.build_settings['GCC_PREPROCESSOR_DEFINITIONS']
        defs = ['$(inherited)'] if defs.nil?
        defs = defs.is_a?(Array) ? defs : [defs]
        defs = defs.flatten
        unless defs.any? { |d| d.to_s.include?('FOLLY_CFG_NO_COROUTINES') }
          defs << 'FOLLY_CFG_NO_COROUTINES=1'
        end
        cfg.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = defs
        if target.name == 'RCT-Folly'
          cfg.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)']
          cfg.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << '_LIBCPP_ENABLE_CXX17_REMOVED_UNARY_BINARY_FUNCTION=1'
        end
        if target.name == 'BoringSSL-GRPC'
          cfg.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'NO'
          ['OTHER_CFLAGS', 'OTHER_CPLUSPLUSFLAGS'].each do |key|
            flags = cfg.build_settings[key]
            next unless flags
            flags = flags.is_a?(Array) ? flags : flags.split
            flags.reject! { |f| f.to_s.include?('GCC_WARN_INHIBIT') }
            cfg.build_settings[key] = flags
          end
        end
        # Static frameworks + Clang modules: RNFB* headers hit bogus
        # "RCTPromiseRejectBlock must be imported from RNFBApp" (invertase/react-native-firebase).
        if target.name.start_with?('RNFB')
          cfg.build_settings['CLANG_ENABLE_MODULES'] = 'NO'
        end
      end
    end
    installer.pods_project.targets.each do |target|
      next unless target.name == 'BoringSSL-GRPC'
      target.source_build_phase.files.each do |file|
        next unless file.settings && file.settings['COMPILER_FLAGS']
        flags = file.settings['COMPILER_FLAGS'].to_s.split
        flags.reject! { |flag| flag.include?('GCC_WARN_INHIBIT') }
        file.settings['COMPILER_FLAGS'] = flags.join(' ')
      end
      pods_project_path = installer.sandbox.project_path
      project_path = File.join(pods_project_path, 'project.pbxproj')
      next unless File.exist?(project_path)
      project_content = File.read(project_path)
      project_content.gsub!('-GCC_WARN_INHIBIT_ALL_WARNINGS', '-w')
      File.write(project_path, project_content)
    end
  end
end
