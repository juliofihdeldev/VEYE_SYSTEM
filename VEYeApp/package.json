    "@react-native-firebase/auth": "^23.8.8",
    "@react-native-firebase/firestore": "^23.8.8",
    "@react-native-firebase/messaging": "^23.8.8",
    "@react-native-picker/picker": "^2.11.0",
    "@react-navigation/bottom-tabs": "^7.15.2",
    "@react-navigation/native": "^7.1.31",
    "@react-navigation/native-stack": "^7.14.2",
    "@shopify/flash-list": "^2.2.2",
    "axios": "^1.3.4",
    "i18next": "^25.8.13",
    "moment": "^2.29.4",
    "react": "19.2.3",
    "react-i18next": "^16.5.4",
    "react-native": "0.84.1",
    "react-native-better-image": "^0.0.3",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-image-picker": "^8.2.1",
