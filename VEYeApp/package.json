{
  "name": "veyeapp",
  "version": "0.0.22",
  "private": true,
  "scripts": {
    "android": "JAVA_HOME=$(/usr/libexec/java_home -v 17) react-native run-android --appId tech.transitiondigitaleht.veye",
    "android:release": "cd android && JAVA_HOME=$(/usr/libexec/java_home -v 17 2>/dev/null || true) ./gradlew assembleRelease",
    "ios": "react-native run-ios --udid 2C6D1EB0-3069-481D-A6B9-B6EC3FB88F9B",
    "lint": "eslint .",
    "start": "react-native start",
    "start:reset": "react-native start --reset-cache",
    "test": "jest",
    "fastlane:setup": "bundle exec fastlane ios setup_certs",
    "fastlane:build": "bundle exec fastlane ios local_build",
    "fastlane:beta": "bundle exec fastlane ios local_beta",
    "fastlane:all": "bundle exec fastlane ios local_build && bundle exec fastlane ios local_beta",
    "fastlane:release": "bundle exec fastlane ios local_release"
  },
  "dependencies": {
    "@notifee/react-native": "^9.1.8",
