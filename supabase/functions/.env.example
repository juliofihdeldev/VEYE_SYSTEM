# Copy to `.env` in this folder (same directory as each function’s `index.ts` parent).
# `supabase functions serve` loads this; see https://supabase.com/docs/guides/functions/secrets
#
# Never commit `.env`.

TELEGRAM_BOT_TOKEN=
# Optional comma-separated numeric channel ids (Telegram) to limit processing
TELEGRAM_CHANNEL_IDS=

# AI pipeline / geocoding
GOOGLE_GEMINI_API_KEY=
GOOGLE_GEOCODING_API_KEY=

# Firebase Cloud Messaging (push notifications) — required by send-notification + ai_pipeline
# FCM_SERVICE_ACCOUNT_JSON must be the *entire* downloaded service-account file as a single
# string, exactly as Google emits it (literal "\n" sequences inside private_key are fine).
# Get it from: Firebase Console → Project Settings → Service accounts → "Generate new private key".
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON=
