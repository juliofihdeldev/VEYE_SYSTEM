# Copy to `.env.desktop` (same folder as vite.config.ts). Used only for:
#   pnpm run build:tauri-frontend   (Tauri `beforeBuildCommand`) → production bundle → hosted Supabase.
#
# `pnpm dev` / `pnpm tauri dev` still use `.env` and auto-switch to local API on localhost (see .env.example).

VITE_USE_REMOTE_SUPABASE=true
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
VITE_PROCESS_ALERT_SECRET=
