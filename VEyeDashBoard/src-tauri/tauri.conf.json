{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VEYe Dashboard",
  "version": "../package.json",
  "identifier": "com.veye.dashboard",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm run build:tauri-frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VEYe Dashboard",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/128x128.png"]
  },
  "plugins": {}
}
