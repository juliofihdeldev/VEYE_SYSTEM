# Supabase (Phase B — Auth + reads + Edge invoke)
# This file must be copied to VEyeDashBoard/.env (next to vite.config.ts). A .env at the monorepo root alone is ignored.
#
# Hosted: https://<project-ref>.supabase.co  (Settings → API — Project URL, no /rest path; custom domains: full https origin)
# Local CLI: http://127.0.0.1:54321  (http only — run `supabase start`, then `supabase status` for keys)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Localhost dev → local API (supabase start / supabase functions serve) automatically uses http://127.0.0.1:54321
# and the default demo anon JWT unless you override below. Keep hosted values above for production builds / preview.
# VITE_USE_REMOTE_SUPABASE=true   # stay on hosted Supabase while opening http://localhost:5173
# VITE_USE_LOCAL_SUPABASE=true    # force local API even when not on localhost (e.g. phone → LAN Vite)
# VITE_USE_LOCAL_SUPABASE=false   # on localhost, still use VITE_SUPABASE_URL (hosted)
# VITE_LOCAL_SUPABASE_URL=http://127.0.0.1:54321
# VITE_LOCAL_SUPABASE_ANON_KEY=   # optional; run: supabase status -o env  (ANON_KEY=...)

# Must match Edge secret PROCESS_ALERT_SECRET when set (required for dashboard-mutate, telegram-monitor secret, etc.)
VITE_PROCESS_ALERT_SECRET=

# Optional: override Telegram trigger URL (otherwise uses VITE_SUPABASE_URL/functions/v1/telegram-monitor)
# VITE_TELEGRAM_MONITOR_RUN_URL=

# Auth: enable Email provider in Supabase Dashboard → Authentication → Providers.
# Add redirect URLs: http://localhost:5173/auth/reset and your production /auth/reset (see supabase/config.toml for local defaults).
#
# Login troubleshooting (localhost):
# - “Email not confirmed”: Authentication → Users → select user → Confirm user, OR disable “Confirm email” on the Email provider (dev).
# - “Invalid login credentials”: wrong password, or user was created in another project than VITE_SUPABASE_URL.
# - New .env values require restarting `pnpm dev:dashboard`.

# --- Tauri desktop (optional) ---
# Full guide: ../docs/TAURI_DASHBOARD.md
#
# Dev (browser or `pnpm tauri:dev`): same `.env` as above; on localhost the app still targets local Supabase unless you set VITE_USE_REMOTE_SUPABASE=true.
#
# Production desktop build uses **hosted** Supabase: copy `.env.desktop.example` → `.env.desktop` (live URL + anon + secret), then:
#   pnpm tauri:build
# or from repo root: `pnpm build:dashboard:tauri`
# Requires Rust + platform deps: https://tauri.app/start/prerequisites/
