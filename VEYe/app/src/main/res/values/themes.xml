<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.VEYe" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:fontFamily">@font/montserrat_regular</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <!-- No automatic scrim over transparent system bars (API 29+). -->
        <item name="android:enforceStatusBarContrast" tools:targetApi="29">false</item>
        <item name="android:enforceNavigationBarContrast" tools:targetApi="29">false</item>
    </style>

    <!-- Cold start: VEYe brand mark over a midnight surface. The PNG is the canonical
         brand asset (also used as the launcher foreground) so the cold-start frame
         reads identically to the launcher icon the user just tapped. The actual hold
         time is driven by `MainViewModel.splashHoldActive` via `setKeepOnScreenCondition`,
         and `MainActivity.handleSplashExit` runs a scale + fade crossfade on the icon
         view so the hand-off to the home shell stays smooth even though the icon itself
         is a raster. -->
    <style name="Theme.VEYe.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_screen_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_brand</item>
        <item name="windowSplashScreenAnimationDuration">500</item>
        <item name="postSplashScreenTheme">@style/Theme.VEYe</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:enforceStatusBarContrast" tools:targetApi="29">false</item>
        <item name="android:enforceNavigationBarContrast" tools:targetApi="29">false</item>
    </style>
</resources>
