<?xml version="1.0" encoding="utf-8"?>
<!--
    "Watchful Eye" cold-start animation. Plays once on every cold start through the
    AndroidX SplashScreen API. Two simultaneous gestures, both starting at t=0:

      • iris_group   scales 0.85 → 1.0 over 240ms (eye snaps into focus)
      • pulse_group  scales 0.7 → 1.9 over 800ms while pulse_ring fades 0.45 → 0.0
        (a single radar pulse — the "veye" / "we are watching, network is live" cue)

    No `android:startOffset` because that attribute is not honoured on every device
    when set directly on <objectAnimator>; running both gestures concurrently keeps
    the AVD bullet-proof across API 26+.

    Viewport is 108×108 to match the adaptive-icon spec; visible content is kept inside
    a 72dp safe zone so it survives whatever masking the platform may apply on legacy
    devices.
-->
<animated-vector
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">
    <aapt:attr name="android:drawable">
        <vector
            android:width="108dp"
            android:height="108dp"
            android:viewportWidth="108"
            android:viewportHeight="108">

            <group
                android:name="pulse_group"
                android:pivotX="54"
                android:pivotY="54"
                android:scaleX="1"
                android:scaleY="1">
                <path
                    android:name="pulse_ring"
                    android:fillColor="#00000000"
                    android:strokeColor="#1F8A70"
                    android:strokeWidth="2"
                    android:strokeAlpha="0.45"
                    android:pathData="M 54,54 m -26,0 a 26,26 0 1,0 52,0 a 26,26 0 1,0 -52,0" />
            </group>

            <path
                android:name="eye_outline"
                android:fillColor="#00000000"
                android:strokeColor="#FFFFFFFF"
                android:strokeWidth="2.5"
                android:strokeLineCap="round"
                android:strokeLineJoin="round"
                android:pathData="M 24,54 C 32,42 44,38 54,38 C 64,38 76,42 84,54 C 76,66 64,70 54,70 C 44,70 32,66 24,54 Z" />

            <group
                android:name="iris_group"
                android:pivotX="54"
                android:pivotY="54"
                android:scaleX="0.85"
                android:scaleY="0.85">
                <path
                    android:name="iris"
                    android:fillColor="#1F8A70"
                    android:pathData="M 54,54 m -10,0 a 10,10 0 1,0 20,0 a 10,10 0 1,0 -20,0" />
                <path
                    android:name="pupil"
                    android:fillColor="#0A0F1C"
                    android:pathData="M 54,54 m -4,0 a 4,4 0 1,0 8,0 a 4,4 0 1,0 -8,0" />
                <path
                    android:name="glint"
                    android:fillColor="#FFFFFFFF"
                    android:fillAlpha="0.9"
                    android:pathData="M 52,51 m -1.4,0 a 1.4,1.4 0 1,0 2.8,0 a 1.4,1.4 0 1,0 -2.8,0" />
            </group>
        </vector>
    </aapt:attr>

    <target android:name="iris_group">
        <aapt:attr name="android:animation">
            <set android:ordering="together">
                <objectAnimator
                    android:propertyName="scaleX"
                    android:valueFrom="0.85"
                    android:valueTo="1.0"
                    android:duration="240"
                    android:interpolator="@android:interpolator/decelerate_cubic" />
                <objectAnimator
                    android:propertyName="scaleY"
                    android:valueFrom="0.85"
                    android:valueTo="1.0"
                    android:duration="240"
                    android:interpolator="@android:interpolator/decelerate_cubic" />
            </set>
        </aapt:attr>
    </target>

    <target android:name="pulse_group">
        <aapt:attr name="android:animation">
            <set android:ordering="together">
                <objectAnimator
                    android:propertyName="scaleX"
                    android:valueFrom="0.7"
                    android:valueTo="1.9"
                    android:duration="800"
                    android:interpolator="@android:interpolator/decelerate_quint" />
                <objectAnimator
                    android:propertyName="scaleY"
                    android:valueFrom="0.7"
                    android:valueTo="1.9"
                    android:duration="800"
                    android:interpolator="@android:interpolator/decelerate_quint" />
            </set>
        </aapt:attr>
    </target>

    <target android:name="pulse_ring">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="strokeAlpha"
                android:valueFrom="0.45"
                android:valueTo="0.0"
                android:duration="800"
                android:interpolator="@android:interpolator/accelerate_quad" />
        </aapt:attr>
    </target>
</animated-vector>
